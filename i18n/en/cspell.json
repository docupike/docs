{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "language": "en_us",
    "minWordLength": 3,
    "dictionaries": [
        "project"
    ],
    "dictionaryDefinitions": [
        {
            "name": "project",
            "path": "./spelling.txt"
        }
    ],
    "ignoreRegExpList": [
        "/(~~~+)\\s?[\\s\\S]+?\\1/g",
        "/(```+)\\s?[\\s\\S]+?\\1/g",
        "/`(.+)`/g",
        "/{{ (.+) }}/g",
        "/{% (.+) %}/g"
    ],
    "ignorePaths": [
        "**/changelog.md",
        "**/CHANGELOG.md",
        "**/release-notes.md",
        "**/RELEASE-NOTES.md",
        "**/RELEASENOTES.md",
        "**/CONTRIBUTING.md",
        "**/GUIDELINES.md",
        "**/SUPPORT.md",
        "**/README.md",
        "**/SECURITY.md",
        "**/CODE_OF_CONDUCT.md"
    ]
}
